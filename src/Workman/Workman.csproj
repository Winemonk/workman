<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>Apps\Resources\wm@64.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="Apps\Resources\bak\**" />
    <EmbeddedResource Remove="Apps\Resources\bak\**" />
    <None Remove="Apps\Resources\bak\**" />
    <Page Remove="Apps\Resources\bak\**" />
  </ItemGroup>

  <ItemGroup>
    <None Remove="Apps\Resources\wm%4064.png" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Apps\Resources\wm@64.ico" />
  </ItemGroup>
	
  <ItemGroup>
	<PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
    <PackageReference Include="DryIoc.Microsoft.DependencyInjection" Version="6.2.0" />
    <PackageReference Include="Hardcodet.NotifyIcon.Wpf" Version="2.0.1" />
    <PackageReference Include="Microsoft.Extensions.Configuration" Version="8.0.0" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" Version="8.0.1" />
    <PackageReference Include="Prism.DryIoc" Version="9.0.537" />
	<PackageReference Include="Microsoft.EntityFrameworkCore" Version="8.0.23" />
  	<PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="8.0.23" />
	<PackageReference Include="Microsoft.EntityFrameworkCore.Tools" Version="8.0.23">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>
	
  
  <ItemGroup>
    <ProjectReference Include="..\Hearth.Prism.Toolkit\Hearth.Prism.Toolkit.csproj" />
  </ItemGroup>


  <ItemGroup>
    <Resource Include="Apps\Resources\add32.png" />
    <Resource Include="Apps\Resources\back32.png" />
    <Resource Include="Apps\Resources\close32.png" />
    <Resource Include="Apps\Resources\current32.png" />
    <Resource Include="Apps\Resources\delete32.png" />
    <Resource Include="Apps\Resources\dock_screen32.png" />
    <Resource Include="Apps\Resources\down32.png" />
    <Resource Include="Apps\Resources\edit32.png" />
    <Resource Include="Apps\Resources\export32.png" />
    <Resource Include="Apps\Resources\folder32.png" />
    <Resource Include="Apps\Resources\home32.png" />
    <Resource Include="Apps\Resources\list32.png" />
    <Resource Include="Apps\Resources\next32.png" />
    <Resource Include="Apps\Resources\save32.png" />
    <Resource Include="Apps\Resources\setting32.png" />
    <Resource Include="Apps\Resources\upward32.png" />
    <Resource Include="Apps\Resources\wm@64.png" />
  </ItemGroup>


  <ItemGroup>
    <None Update="appsettings.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
    <None Update="wm.db">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
