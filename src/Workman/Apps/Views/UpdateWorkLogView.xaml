<UserControl
    x:Class="Workman.Apps.Views.UpdateWorkLogView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Workman.Apps.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    Width="200"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">
    <Grid>
        <StackPanel Orientation="Vertical">
            <Label Content="{Binding Task, Source={StaticResource LocalizationManager}}" />
            <ComboBox
                Margin="3"
                ItemsSource="{Binding Tasks}"
                SelectedItem="{Binding SelectedTask, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Label Content="{Binding Content, Source={StaticResource LocalizationManager}}" />
            <TextBox Text="{Binding Content, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Label Content="{Binding ElapsedTime, Source={StaticResource LocalizationManager}}" />
            <DockPanel Margin="3">
                <UniformGrid DockPanel.Dock="Right" Rows="2">
                    <Button
                        Width="20"
                        Height="9"
                        Margin="0"
                        Padding="0"
                        Background="Transparent"
                        Command="{Binding IncreaseElapsedTimeCommand}"
                        FontSize="7">
                        <Path Data="M 0 5 L 7 0 L 14 5 Z" Fill="Black" />
                    </Button>
                    <Button
                        Width="20"
                        Height="9"
                        Margin="0"
                        Padding="0"
                        Background="Transparent"
                        Command="{Binding DecreaseElapsedTimeCommand}"
                        FontSize="7">
                        <Path Data="M 0 0 L 7 5 L 14 0 Z" Fill="Black" />
                    </Button>
                </UniformGrid>
                <TextBox Text="{Binding ElapsedTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </DockPanel>
            <StackPanel
                Margin="3"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <Button Command="{Binding ConfirmCommand}" Content="{Binding Confirm, Source={StaticResource LocalizationManager}}" />
                <Button Command="{Binding CancelCommand}" Content="{Binding Cancel, Source={StaticResource LocalizationManager}}" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
