<UserControl
    x:Class="Workman.Apps.Views.UpdateWorkLogView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Workman.Apps.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    Width="200"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">
    <Grid>
        <StackPanel Orientation="Vertical">
            <Label Content="项目：" />
            <ComboBox
                Margin="3"
                DisplayMemberPath="Name"
                ItemsSource="{Binding Projects}"
                SelectedItem="{Binding SelectedProject, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Label Content="内容：" />
            <TextBox Margin="3" Text="{Binding Content, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Label Content="耗时：" />
            <TextBox Margin="3" Text="{Binding ElapsedTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <StackPanel
                Margin="3"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <Button Command="{Binding ConfirmCommand}" Content="确 认" />
                <Button Command="{Binding CancelCommand}" Content="取 消" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
