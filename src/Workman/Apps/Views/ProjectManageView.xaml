<UserControl
    x:Class="Workman.Apps.Views.ProjectManageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Workman.Apps.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    Width="280"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">
    <Grid>
        <StackPanel Orientation="Vertical">
            <DockPanel>
                <Label Content="项目列表：" />
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button
                        Margin="3,1"
                        Command="{Binding CreateProjectCommand}"
                        Content="新建项目" />
                </StackPanel>
            </DockPanel>
            <ListBox
                MaxHeight="92"
                Margin="3"
                HorizontalContentAlignment="Stretch"
                d:ItemsSource="{d:SampleData}"
                Background="Transparent"
                ItemsSource="{Binding Projects}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <DockPanel>
                            <Label Content="{Binding Name}" />
                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                <Button
                                    Margin="3,1"
                                    Command="{Binding DataContext.DeleteProjectCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ListBox}}"
                                    CommandParameter="{Binding .}"
                                    Cursor="Hand">
                                    <Image
                                        Width="16"
                                        Height="16"
                                        Source="/Apps/Resources/delete32.png" />
                                </Button>
                            </StackPanel>
                        </DockPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <StackPanel
                Margin="3"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <Button Command="{Binding CancelCommand}" Content="关 闭" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
