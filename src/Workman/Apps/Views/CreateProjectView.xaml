<UserControl
    x:Class="Workman.Apps.Views.CreateProjectView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Workman.Apps.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    Width="200"
    d:DesignHeight="150"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">
    <StackPanel Orientation="Vertical">
        <Label>项目名称：</Label>
        <TextBox Margin="3" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        <StackPanel
            Margin="3"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button Command="{Binding ConfirmCommand}" Content="确 认" />
            <Button Command="{Binding CancelCommand}" Content="取 消" />
        </StackPanel>
    </StackPanel>
</UserControl>
