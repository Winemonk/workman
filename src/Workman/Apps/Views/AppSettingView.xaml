<UserControl
    x:Class="Workman.Apps.Views.AppSettingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Workman.Apps.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    Width="280"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <ScrollViewer
            Height="180"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <StackPanel Orientation="Vertical">
                <DockPanel Margin="3">
                    <Label Width="108" Content="{Binding AutoStartup, Source={StaticResource LocalizationManager}}" />
                    <RibbonCheckBox IsChecked="{Binding Autostart}" />
                </DockPanel>
                <DockPanel Margin="3">
                    <Label Width="108" Content="{Binding DockMainScreen, Source={StaticResource LocalizationManager}}" />
                    <RibbonCheckBox IsChecked="{Binding DockOnlyMainScreen}" />
                </DockPanel>
                <DockPanel Margin="3">
                    <Label Width="108" Content="{Binding TurnOnReminder, Source={StaticResource LocalizationManager}}" />
                    <RibbonCheckBox IsChecked="{Binding TurnOnReminder}" />
                </DockPanel>
                <DockPanel Margin="3">
                    <Label Width="108" Content="{Binding ReminderOfStartTime, Source={StaticResource LocalizationManager}}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox HorizontalContentAlignment="Center" Text="{Binding ReminderStartTimeHour, StringFormat=D2}" />
                        <Label Grid.Column="1" Content=":" />
                        <TextBox
                            Grid.Column="2"
                            HorizontalContentAlignment="Center"
                            Text="{Binding ReminderStartTimeMinute, StringFormat=D2}" />
                    </Grid>
                </DockPanel>
                <DockPanel Margin="3">
                    <Label Width="108" Content="{Binding ReminderInterval, Source={StaticResource LocalizationManager}}" />
                    <TextBox HorizontalContentAlignment="Center" Text="{Binding ReminderInterval}" />
                </DockPanel>
            </StackPanel>
        </ScrollViewer>
        <UniformGrid Grid.Row="1" Rows="1">
            <Button Command="{Binding ExitCommand}">
                <StackPanel Orientation="Horizontal">
                    <Image
                        Width="16"
                        Height="16"
                        Margin="2"
                        Source="/Apps/Resources/close32.png" />
                    <TextBlock
                        Margin="2"
                        Foreground="Red"
                        Text="{Binding Exit, Source={StaticResource LocalizationManager}}" />
                </StackPanel>
            </Button>
            <Button Command="{Binding CancelCommand}">
                <StackPanel Orientation="Horizontal">
                    <Image
                        Width="16"
                        Height="16"
                        Margin="2"
                        Source="/Apps/Resources/save32.png" />
                    <TextBlock Margin="2" Text="{Binding SaveAndClose, Source={StaticResource LocalizationManager}}" />
                </StackPanel>
            </Button>
        </UniformGrid>
    </Grid>
</UserControl>
