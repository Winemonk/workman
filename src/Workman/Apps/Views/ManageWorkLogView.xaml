<UserControl
    x:Class="Workman.Apps.Views.ManageWorkLogView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Workman.Apps.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    Width="520"
    Height="360"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <Label
            Grid.Row="0"
            Content="{Binding LogManage, Source={StaticResource LocalizationManager}}"
            FontWeight="Bold" />
        <DockPanel Grid.Row="1">
            <Label Content="{Binding Task, Source={StaticResource LocalizationManager}}" />
            <Button
                Command="{Binding CreateLogCommand}"
                Content="{Binding AddLog, Source={StaticResource LocalizationManager}}"
                DockPanel.Dock="Right" />
            <ComboBox
                Margin="3"
                ItemsSource="{Binding Tasks}"
                SelectedItem="{Binding SelectedTask, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </DockPanel>
        <DataGrid
            Grid.Row="2"
            IsReadOnly="True"
            ItemsSource="{Binding Logs}">
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding OrderId}" Header="{Binding IDX, Source={StaticResource LocalizationManager}}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding Date, Converter={StaticResource DateTimeToLongDateStringConverter}}" Header="{Binding Date, Source={StaticResource LocalizationManager}}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Content}"
                    Header="{Binding Content, Source={StaticResource LocalizationManager}}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="TextWrapping" Value="Wrap" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding ElapsedTime}" Header="{Binding ElapsedTime, Source={StaticResource LocalizationManager}}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn MinWidth="60" Header="{Binding Operation, Source={StaticResource LocalizationManager}}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                <Button
                                    Margin="3,1"
                                    VerticalAlignment="Center"
                                    Command="{Binding DataContext.EditLogCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGrid}}"
                                    CommandParameter="{Binding .}"
                                    Cursor="Hand"
                                    ToolTip="{Binding Edit, Source={StaticResource LocalizationManager}}">
                                    <Image
                                        Width="16"
                                        Height="16"
                                        Source="/Apps/Resources/edit32.png" />
                                </Button>
                                <Button
                                    Margin="3,1"
                                    VerticalAlignment="Center"
                                    Command="{Binding DataContext.DeleteLogCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGrid}}"
                                    CommandParameter="{Binding .}"
                                    Cursor="Hand"
                                    ToolTip="{Binding Delete, Source={StaticResource LocalizationManager}}">
                                    <Image
                                        Width="16"
                                        Height="16"
                                        Source="/Apps/Resources/delete32.png" />
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel
            Grid.Row="3"
            Margin="3"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button Command="{Binding CancelCommand}" Content="{Binding Close, Source={StaticResource LocalizationManager}}" />
        </StackPanel>
    </Grid>
</UserControl>
