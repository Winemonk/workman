<UserControl
    x:Class="Workman.Apps.Views.CreateWorkLogView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:Workman.Apps.Helpers"
    xmlns:local="clr-namespace:Workman.Apps.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    Width="520"
    Height="360"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <Label Grid.Row="0" Content="{Binding AddLog, Source={StaticResource LocalizationManager}}" />
        <DataGrid
            Grid.Row="1"
            Margin="3"
            d:ItemsSource="{d:SampleData}"
            CanUserAddRows="True"
            CanUserDeleteRows="True"
            HeadersVisibility="All"
            ItemsSource="{Binding WorkLogs}">
            <DataGrid.Resources>
                <helpers:BindingProxy x:Key="BindingProxy" DataContext="{Binding}" />
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn
                    Binding="{Binding OrderId}"
                    Header="{Binding IDX, Source={StaticResource LocalizationManager}}"
                    IsReadOnly="True" />
                <DataGridComboBoxColumn
                    Width="*"
                    Header="{Binding Task, Source={StaticResource LocalizationManager}}"
                    ItemsSource="{Binding DataContext.Tasks, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Source={StaticResource BindingProxy}}"
                    SelectedItemBinding="{Binding Task}" />
                <DataGridTextColumn
                    Width="*"
                    MinWidth="100"
                    Binding="{Binding Content, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Header="{Binding Content, Source={StaticResource LocalizationManager}}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="TextWrapping" Value="Wrap" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding ElapsedTime}" Header="{Binding ElapsedTime, Source={StaticResource LocalizationManager}}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn MinWidth="180" Header="{Binding Date, Source={StaticResource LocalizationManager}}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <DatePicker
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                SelectedDate="{Binding Date, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                SelectedDateFormat="Long" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <DockPanel Grid.Row="2">
            <Label>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Enter: " />
                    <TextBlock Text="{Binding NewRow, Source={StaticResource LocalizationManager}}" />
                </StackPanel>
            </Label>
            <Label>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Del: " />
                    <TextBlock Text="{Binding DeleteRow, Source={StaticResource LocalizationManager}}" />
                </StackPanel>
            </Label>
            <StackPanel
                Margin="3"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <Button Command="{Binding ConfirmCommand}" Content="{Binding Confirm, Source={StaticResource LocalizationManager}}" />
                <Button Command="{Binding CancelCommand}" Content="{Binding Cancel, Source={StaticResource LocalizationManager}}" />
            </StackPanel>
        </DockPanel>
    </Grid>
</UserControl>
