<UserControl
    x:Class="Workman.Apps.Views.TaskManageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Workman.Apps.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    Width="520"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">
    <StackPanel Orientation="Vertical">
        <Label Content="{Binding TaskManage, Source={StaticResource LocalizationManager}}" FontWeight="Bold" />
        <DockPanel>
            <Label Content="{Binding Iteration, Source={StaticResource LocalizationManager}}" />
            <Button
                Command="{Binding CreateTaskCommand}"
                Content="{Binding NewTask, Source={StaticResource LocalizationManager}}"
                DockPanel.Dock="Right" />
            <ComboBox
                Margin="3"
                DisplayMemberPath="Name"
                ItemsSource="{Binding Projects}"
                SelectedItem="{Binding SelectedProject, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </DockPanel>
        <DataGrid
            Grid.Row="1"
            MinHeight="100"
            IsReadOnly="True"
            ItemsSource="{Binding Tasks}">
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding OrderId}" Header="{Binding IDX, Source={StaticResource LocalizationManager}}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Width="*" Header="{Binding Task, Source={StaticResource LocalizationManager}}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="TextWrapping" Value="Wrap" />
                            <Setter Property="Text" Value="{Binding Name}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.SelectedProject.Id, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGrid}}" Value="-1">
                                    <Setter Property="Text" Value="{Binding}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding TotalElapsedTime}" Header="{Binding TotalElapsedTime, Source={StaticResource LocalizationManager}}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn
                    Width="60"
                    CanUserResize="False"
                    CanUserSort="False"
                    Header="{Binding Operation, Source={StaticResource LocalizationManager}}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                <Button
                                    Margin="3,1"
                                    VerticalAlignment="Center"
                                    Command="{Binding DataContext.EditTaskCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGrid}}"
                                    CommandParameter="{Binding .}"
                                    Cursor="Hand"
                                    ToolTip="{Binding Edit, Source={StaticResource LocalizationManager}}">
                                    <Image
                                        Width="16"
                                        Height="16"
                                        Source="/Apps/Resources/edit32.png" />
                                </Button>
                                <Button
                                    Margin="3,1"
                                    VerticalAlignment="Center"
                                    Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGrid}}"
                                    CommandParameter="{Binding .}"
                                    Cursor="Hand"
                                    ToolTip="{Binding Delete, Source={StaticResource LocalizationManager}}">
                                    <Image
                                        Width="16"
                                        Height="16"
                                        Source="/Apps/Resources/delete32.png" />
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel
            Grid.Row="2"
            Margin="3"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button Command="{Binding CancelCommand}" Content="{Binding Close, Source={StaticResource LocalizationManager}}" />
        </StackPanel>
    </StackPanel>
</UserControl>
