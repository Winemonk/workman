<UserControl
    x:Class="Workman.Apps.Views.ManageWorkProjectView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Workman.Apps.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    Width="520"
    Height="360"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Vertical">
            <Label Content="{Binding IterationManage, Source={StaticResource LocalizationManager}}" FontWeight="Bold" />
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button
                    Margin="3,1"
                    Command="{Binding CreateProjectCommand}"
                    Content="{Binding NewIteration, Source={StaticResource LocalizationManager}}" />
            </StackPanel>
        </StackPanel>
        <DataGrid
            Grid.Row="1"
            Margin="3"
            IsReadOnly="True"
            ItemsSource="{Binding Projects}">
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding OrderId}" Header="{Binding IDX, Source={StaticResource LocalizationManager}}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding}"
                    Header="{Binding Name, Source={StaticResource LocalizationManager}}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding TaskCount}" Header="{Binding TaskCount, Source={StaticResource LocalizationManager}}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding ElapsedTime}" Header="{Binding TotalElapsedTime, Source={StaticResource LocalizationManager}}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridCheckBoxColumn Binding="{Binding IsArchived}" Header="{Binding Archive, Source={StaticResource LocalizationManager}}">
                    <DataGridCheckBoxColumn.ElementStyle>
                        <Style TargetType="CheckBox">
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="IsHitTestVisible" Value="False" />
                        </Style>
                    </DataGridCheckBoxColumn.ElementStyle>
                </DataGridCheckBoxColumn>
                <DataGridTextColumn Binding="{Binding CreatedTime, Converter={StaticResource DateTimeToShortDateStringConverter}}" Header="{Binding CreatedTime, Source={StaticResource LocalizationManager}}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding ArchivedTime, Converter={StaticResource DateTimeToShortDateStringConverter}}" Header="{Binding ArchivedTime, Source={StaticResource LocalizationManager}}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn MinWidth="90" Header="{Binding Operation, Source={StaticResource LocalizationManager}}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                <Button
                                    Margin="3,1"
                                    Command="{Binding DataContext.ManageTaskCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGrid}}"
                                    CommandParameter="{Binding .}"
                                    Cursor="Hand"
                                    ToolTip="{Binding TaskManage, Source={StaticResource LocalizationManager}}">
                                    <Image
                                        Width="16"
                                        Height="16"
                                        Source="/Apps/Resources/list32.png" />
                                </Button>
                                <Button
                                    Margin="3,1"
                                    Command="{Binding DataContext.EditProjectCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGrid}}"
                                    CommandParameter="{Binding .}"
                                    Cursor="Hand"
                                    ToolTip="{Binding Edit, Source={StaticResource LocalizationManager}}">
                                    <Image
                                        Width="16"
                                        Height="16"
                                        Source="/Apps/Resources/edit32.png" />
                                </Button>
                                <Button
                                    Margin="3,1"
                                    Command="{Binding DataContext.DeleteProjectCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGrid}}"
                                    CommandParameter="{Binding .}"
                                    Cursor="Hand"
                                    ToolTip="{Binding Delete, Source={StaticResource LocalizationManager}}">
                                    <Image
                                        Width="16"
                                        Height="16"
                                        Source="/Apps/Resources/delete32.png" />
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel
            Grid.Row="2"
            Margin="3"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button Command="{Binding CancelCommand}" Content="{Binding Close, Source={StaticResource LocalizationManager}}" />
        </StackPanel>
    </Grid>
</UserControl>
