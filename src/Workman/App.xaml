<prism:PrismApplication
    x:Class="Workman.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:apps="clr-namespace:Workman.Apps"
    xmlns:helpers="clr-namespace:Workman.Apps.Helpers"
    xmlns:local="clr-namespace:Workman"
    xmlns:prism="http://prismlibrary.com/">
    <prism:PrismApplication.Resources>
        <ResourceDictionary>
            <ObjectDataProvider x:Key="LocalizationManager" ObjectInstance="{x:Static apps:LocalizationManager.Instance}" />
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <helpers:DateTimeToLongDateStringConverter x:Key="DateTimeToLongDateStringConverter" />
            <helpers:DateTimeToShortDateStringConverter x:Key="DateTimeToShortDateStringConverter" />
            <helpers:CalendarDayButtonBrushConverter x:Key="CalendarDayButtonBrushConverter" />
            <Style TargetType="TextBlock">
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
            <Style TargetType="TextBox">
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>
            <Style TargetType="ToggleButton">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Padding" Value="3" />
            </Style>
            <Style TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Margin" Value="3" />
                <Setter Property="Padding" Value="3,1" />
            </Style>
            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="#66ffffff" />
                <Setter Property="Padding" Value="5,1" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
            </Style>
            <Style TargetType="DataGridRow">
                <Setter Property="Background" Value="#66ffffff" />
            </Style>
            <Style TargetType="DataGridCell">
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>
            <Style TargetType="DataGrid">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="AutoGenerateColumns" Value="False" />
                <Setter Property="CanUserAddRows" Value="False" />
                <Setter Property="GridLinesVisibility" Value="None" />
                <Setter Property="HeadersVisibility" Value="Column" />
            </Style>
            <Style TargetType="Label">
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>
            <Style x:Key="LogCalendarStyle" TargetType="Calendar">
                <Setter Property="CalendarDayButtonStyle">
                    <Setter.Value>
                        <Style TargetType="CalendarDayButton">
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Background" Value="{Binding ., Converter={StaticResource CalendarDayButtonBrushConverter}, ConverterParameter=Background}" />
                            <Setter Property="Foreground" Value="{Binding ., Converter={StaticResource CalendarDayButtonBrushConverter}, ConverterParameter=Foreground}" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Margin" Value="1" />
                            <Setter Property="Padding" Value="5" />
                            <Setter Property="FontSize" Value="15" />
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="CalendarDayButton">
                                        <Border
                                            Margin="{TemplateBinding Margin}"
                                            Padding="{TemplateBinding Padding}"
                                            HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                                            VerticalAlignment="{TemplateBinding VerticalAlignment}"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <!--  今天的日期  -->
                                <Trigger Property="IsToday" Value="True">
                                    <Setter Property="Foreground" Value="#0078D7" />
                                </Trigger>
                                <!--  选中的日期  -->
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#0078D7" />
                                    <Setter Property="Foreground" Value="White" />
                                </Trigger>
                                <!--  非当前月份的日期 (Inactive)  -->
                                <Trigger Property="IsInactive" Value="True">
                                    <Setter Property="FontSize" Value="11" />
                                    <Setter Property="Margin" Value="4" />
                                    <Setter Property="Padding" Value="2" />
                                </Trigger>
                                <!--  被禁用的日期 (Blackout)  -->
                                <Trigger Property="IsBlackedOut" Value="True">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Foreground" Value="#999999" />
                                    <Setter Property="FontSize" Value="11" />
                                </Trigger>
                                <!--  鼠标悬停状态  -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E5F3FF" />
                                    <Setter Property="Foreground" Value="#0078D7" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </prism:PrismApplication.Resources>
</prism:PrismApplication>
